# ─────────────────────────────────────────────────────────
# Giscus — Comments
# ─────────────────────────────────────────────────────────
# 1. Go to https://giscus.app and connect your GitHub repo.
# 2. Enable Discussions on the repo (Settings → Features → Discussions).
# 3. Giscus.app will generate the values below automatically.

NUXT_PUBLIC_GISCUS_REPO=           # e.g. yourusername/your-repo
NUXT_PUBLIC_GISCUS_REPO_ID=        # e.g. R_kgDO...
NUXT_PUBLIC_GISCUS_CATEGORY=General
NUXT_PUBLIC_GISCUS_CATEGORY_ID=    # e.g. DIC_kwDO...

# Leave NUXT_PUBLIC_GISCUS_REPO empty to disable comments entirely.

# ─────────────────────────────────────────────────────────
# Vercel Analytics
# ─────────────────────────────────────────────────────────
# Set to "true" to inject the Vercel Web Analytics script.
# Works out of the box on Vercel — no extra package needed.
# See: https://vercel.com/docs/analytics

NUXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
